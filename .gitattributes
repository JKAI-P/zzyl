# 自动检测文本文件并规范化换行符为 LF
* text=auto

# Java 源代码使用 LF
*.java text eol=lf

# XML 配置文件使用 LF
*.xml text eol=lf

# 属性文件使用 LF
*.properties text eol=lf

# SQL 文件使用 LF
*.sql text eol=lf

# 脚本文件使用 LF
*.sh text eol=lf
*.bash text eol=lf

# 配置文件使用 LF
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.toml text eol=lf

# 文档文件使用 LF
*.md text eol=lf
*.txt text eol=lf

# 二进制文件标记为 binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.jar binary
*.war binary
*.ear binary
